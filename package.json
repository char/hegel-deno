{
  "name": "@hegeldev/hegel",
  "version": "0.4.0",
  "description": "Property-based testing for TypeScript",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hegeldev/hegel-typescript.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./generators": {
      "types": "./dist/generators/index.d.ts",
      "import": "./dist/generators/index.js"
    }
  },
  "files": [
    "dist",
    "native"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "node scripts/fetch-libhegel.mjs --all",
    "test": "vitest run --coverage",
    "lint": "prettier --check . && eslint . && tsc --noEmit",
    "format": "prettier --write .",
    "docs": "typedoc"
  },
  "keywords": [
    "hegel",
    "property-based-testing",
    "hypothesis"
  ],
  "author": "David R. MacIver <david.maciver@antithesis.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "cbor-x": "^1.6.0",
    "koffi": "^3.0.2"
  }
}
